{
  "expo": {
    "name": "Food Tinder",
    "slug": "food-tinder",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "foodtinder",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodtinder.app"
    },
    "android": {
      "package": "com.foodtinder.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF6B6B",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
